{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for the main window — allows the webview to invoke our custom commands and listen for backend events.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:event:allow-listen",
    "core:event:allow-unlisten",
    "core:event:allow-emit",
    "core:webview:default",
    "core:webview:allow-internal-toggle-devtools",
    "core:window:default",
    "core:window:allow-start-dragging",
    "shell:default"
  ]
}
